<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardClienteInfo"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icono -->
        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/pp_usuario"
            android:padding="8dp"
            android:background="@drawable/bg_circle_blue_light" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNombreClienteInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre Cliente"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/gym_blue" />

            <TextView
                android:id="@+id/tvBadgeLesiones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin lesiones activas ✓"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvZonasCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Sin lesiones activas"
                android:textSize="12sp"
                android:textColor="@color/gym_gray"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvRecuperadasCliente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:visibility="gone"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Flecha -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:rotation="180"
            app:tint="@color/gym_gray" />

    </LinearLayout>
</androidx.cardview.widget.CardView>