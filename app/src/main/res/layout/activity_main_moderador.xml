<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainModerador"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gym_bg"
    android:padding="16dp"
    tools:context=".MainActivityModerador">

    <!-- ═══════════════════ HEADER ═══════════════════ -->
    <LinearLayout
        android:id="@+id/headerMod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/pp_usuario"
            android:contentDescription="Perfil moderador" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Panel de moderación,"
                android:textSize="12sp"
                android:textColor="@color/gym_gray" />

            <TextView
                android:id="@+id/tvNombreModerador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/gym_blue" />
        </LinearLayout>

        <!-- Botón cerrar sesión -->
        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/mas"
            android:padding="6dp"
            android:onClick="cerrarSesion"
            android:contentDescription="Cerrar sesión"
            app:tint="@color/gym_gray" />
    </LinearLayout>

    <!-- ═══════════════════ CARD RESUMEN ═══════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardResumenMod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/gym_blue"
        app:layout_constraintTop_toBottomOf="@id/headerMod">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RESUMEN DEL DÍA"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado del gimnasio"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp" />

            <!-- Fila de estadísticas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Reservas activas -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvTotalReservas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/gym_orange" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reservas\nactivas"
                        android:textSize="11sp"
                        android:textColor="@android:color/white"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Clientes registrados -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:id="@+id/tvTotalClientes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clientes\nregistrados"
                        android:textSize="11sp"
                        android:textColor="@android:color/white"
                        android:gravity="center" />
                </LinearLayout>

                <!-- Ausencias hoy -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:padding="10dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:id="@+id/tvTotalAusencias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B6B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ausencias\nhoy"
                        android:textSize="11sp"
                        android:textColor="@android:color/white"
                        android:gravity="center" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════ LABEL ACCIONES ═══════════════════ -->
    <TextView
        android:id="@+id/labelAccionesMod"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gestión"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/gym_blue"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardResumenMod"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ═══════════════════ GRID DE CARDS ═══════════════════ -->
    <LinearLayout
        android:id="@+id/rowMod1"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelAccionesMod">

        <!-- Card Reservas -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardReservasMod"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_orange_light"
                    android:padding="8dp"
                    android:src="@drawable/reserva" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reservas"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/gym_blue"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Clientes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardClientesMod"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_blue_light"
                    android:padding="8dp"
                    android:src="@drawable/pp_usuario" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clientes"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/gym_blue"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rowMod2"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/rowMod1">

        <!-- Card Ausencias -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAusenciasMod"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_orange_light"
                    android:padding="8dp"
                    android:src="@drawable/mas" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ausencias"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/gym_blue"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card Chat -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardChatMod"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_blue_light"
                    android:padding="8dp"
                    android:src="@drawable/chat" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/gym_blue"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ═══════════════════ BOTTOM NAVIGATION ═══════════════════ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationModerador"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu_moderador" />

</androidx.constraintlayout.widget.ConstraintLayout>